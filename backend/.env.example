# ===== Banco de dados (Supabase Postgres) =====
# Pegue em: Supabase > Project Settings > Database > Connection string > "Transaction pooler" (URI)
# Troque [YOUR-PASSWORD] pela senha do banco que voce definiu ao criar o projeto.
# Ex.: postgresql://postgres.xxxxxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ===== Autenticacao JWT =====
# Use uma string longa e aleatoria. Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-isto-por-um-segredo-aleatorio-bem-longo
JWT_EXPIRES_IN=7d

# ===== Servidor =====
PORT=4000
NODE_ENV=development

# Origens permitidas no CORS (separadas por virgula). Use * SO em dev.
# Em producao, trave no dominio do front, ex.: CORS_ORIGIN=https://meudominio.com.br
CORS_ORIGIN=*
